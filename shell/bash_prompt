#!/bin/bash

parse_git_branch() {
  git rev-parse --is-inside-work-tree &>/dev/null || return
  git symbolic-ref --short HEAD 2>/dev/null || git describe --tags --exact-match 2>/dev/null
}

# Colored prompt update
update_prompt() {
  local branch=$(parse_git_branch)

  # Colors: blue for prompt, green for branch
  local BLUE="\[\e[34m\]"
  local GREEN="\[\e[32m\]"
  local RESET="\[\e[0m\]"

  if [[ -n "$branch" ]]; then
    PS1="${BLUE}λ ${RESET}\W ${GREEN}($branch)${RESET} \$ "
  else
    PS1="${BLUE}λ ${RESET}\W \$ "
  fi
}

PROMPT_COMMAND="update_prompt; ${PROMPT_COMMAND}"
