source ~/.config/mutt/passwords
source ~/.config/mutt/themes/dracula

# You can use any gmail imap mailboxes
mailboxes =INBOX =[Gmail]/Sent\ Mail =[Gmail]/Drafts =[Gmail]/Spam =[Gmail]/Trash

# IMAP Settings
set folder=imaps://imap.gmail.com/
set imap_keepalive = 180
set mail_check = 100
set from= $imap_user
set imap_user = $imap_user
set imap_pass=$imap_pass
set realname = "Ryan Nemeth"

# SMTP Settings
set smtp_url = "smtps://$imap_user@smtp.gmail.com:465/"
set smtp_pass = $imap_pass
set smtp_authenticators="gssapi:login"
set ssl_starttls=yes
set ssl_force_tls=yes

# Mailbox Settings
set spoolfile = "imaps://imap.gmail.com/INBOX"
set folder = "imaps://imap.gmail.com/"
set record = "+[Gmail]/Sent Mail"
set postponed = "+[Gmail]/Drafts"

# Editor
set editor=nvim

# Sidebar
set sidebar_width=20
set sidebar_visible=yes
set sidebar_format="%B%?F? [%F]?%* %?N?%N/?%S"

bind index,pager \CN sidebar-next # Ctrl-n Next Folder
bind index,pager \CP sidebar-prev # Ctrl-p Previous Folder
bind index,pager \CI sidebar-open # Ctrl-i Open Folder
bind index,pager \CB sidebar-toggle-visible # Ctrl-b Toggle Sidebar

# Vim like binds
bind attach,index,pager \CD next-page
bind attach,index,pager \CU previous-page
bind pager g top
bind pager G bottom
bind attach,index g first-entry
bind attach,index G last-entry

# Caching
set header_cache = "~/.mutt/cache/headers"
set message_cachedir = "~/.mutt/cache/bodies"

# ...
set use_from=yes
set certificate_file = "~/.mutt/certificates"
set move = no
# https://www.neomutt.org/guide/reference search sleep_time for additional info
set sleep_time=0 # be faster
set beep=no # no beep sound
auto_view text/html
set sort=reverse-date   # default sorting by date
# When sorting by threads, this variable controls how threads are sorted
# in relation to other threads, and how the branches of the thread trees are sorted.
set sort_aux=last-date-received
# Index page format. Default "%4C %Z %{%b %d} %-15.15L (%?l?%4l&%4c?) %s"
set index_format="%4C %Z %{%b %d %R} %-15.15L (%?l?%4l&%4c?) %s"
set mail_check_stats

set mailcap_path = ~/.config/mutt/mailcap

set implicit_autoview
alternative_order text/plain text/html

macro index,pager \cb |urlview\n
